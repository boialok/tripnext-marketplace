<% layout("/layouts/boilerplate") %>

<div class="row mt-5 mb-5">
    <div class="col-12 mb-4">
        <h2 class="fw-bold">Wishlists</h2>
    </div>

    <% if (!wishlist || wishlist.length === 0) { %>
        <div class="col-12 mt-4">
            <h4 class="text-muted fw-semibold">No wishlists created yet</h4>
            <p class="text-muted">As you search, tap the heart icon to save your favorite places.</p>
            <a href="/listings" class="btn mt-3 px-4 py-2" style="background-color: #fe424d; color: white; border: none; border-radius: 0.5rem; font-weight: 600;">Start exploring</a>
        </div>
    <% } else { %>
        <% for (let listing of wishlist) { %>
            <% if (listing) { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
                        <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                            <% 
                                let imageSrc = "";
                                if (listing.images && listing.images.length > 0) {
                                    imageSrc = listing.images[0].url;
                                } else if (listing.image && listing.image.url) {
                                    imageSrc = listing.image.url;
                                } else if (typeof listing.image === 'string') {
                                    imageSrc = listing.image;
                                }
                            %>
                            <img src="<%= imageSrc %>" class="card-img-top" style="height: 250px; object-fit: cover; background-color: #f8f9fa;">
                            
                            <div class="card-body p-3">
                                <h5 class="card-title fw-bold mb-1"><%= listing.title %></h5>
                                <p class="card-text text-muted mb-1" style="font-size: 0.95rem;">
                                    <%= listing.location %>, <%= listing.country %>
                                </p>
                                <div class="mt-2">
                                    <span class="fw-bold fs-5">₹<%= listing.price.toLocaleString("en-IN") %></span> <span class="text-muted">night</span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            <% } %>
        <% } %>
    <% } %>
</div>